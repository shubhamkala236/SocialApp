{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=SHUBHAMPC;Database=AuthDb;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "Jwt": {
        "Secret": "*H^%R<xbnkBHEB1bLz5e7g~4:C`GzI7_",
        "Issuer": "SocialApp",
        "Audience": "SocialApp"
    },
    "ReverseProxy": {
        "Routes": {
            "auth-route": {
                "ClusterId": "auth-cluster",
                "Match": {
                    "Path": "/api/auth/{**catch-all}"
                }
            },
            "posts-route": {
                "ClusterId": "posts-cluster",
                "Match": {
                    "Path": "/api/posts/{**catch-all}"
                },
                "AuthorizationPolicy": "default"
            },
            "posts-public-route": {
                "ClusterId": "posts-cluster",
                "Match": {
                    "Path": "/api/posts",
                    "Methods": [ "GET" ]
                }
            },
            "users-route": {
                "ClusterId": "users-cluster",
                "Match": { "Path": "/api/users/{**catch-all}" }
            },
            "interactions-route": {
                "ClusterId": "interactions-cluster",
                "Match": { "Path": "/api/interactions/{**catch-all}" }
            },
            "ai-route": {
                "ClusterId": "ai-cluster",
                "Match": {
                    "Path": "/api/ai/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "auth-cluster": {
                "Destinations": {
                    "auth-service": {
                        "Address": "http://auth-service:8080"
                    }
                }
            },
            "posts-cluster": {
                "Destinations": {
                    "post-service": {
                        "Address": "http://post-service:8080"
                    }
                }
            },
            "users-cluster": {
                "Destinations": {
                    "user-service": { "Address": "http://user-service:8080" }
                }
            },
            "interactions-cluster": {
                "Destinations": {
                    "interaction-service": { "Address": "http://interaction-service:8080" }
                }
            },
            "ai-cluster": {
                "Destinations": {
                    "ai-service": {
                        "Address": "http://ai-service:8080"
                    }
                }
            }
        }
    }
}
